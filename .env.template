# IPAT Data Watchdog Environment Configuration
# Copy this file to .env and modify as needed

PYTHONPATH=.

# PC Plugin Configuration
# PC_NAME determines which PC plugin to load and automatically selects associated devices
# PC-device mapping is defined in pyproject.toml entry points
# Available PC types:
# - default_pc_blb: sem_phenomxl2
# - lab_workstation_blb: sem_phenomxl2, psa_horibalinks_blb
# - office_desktop_blb: utm_zwick  
# - server_backend_blb: sem_phenomxl2, psa_horibalinks_blb, utm_zwick
PC_NAME=default_pc_blb

# Legacy configuration (kept for backward compatibility with build scripts)
DEVICE_NAMES=sem_phenomxl2
DEVICE_NAME=sem_phenomxl2
