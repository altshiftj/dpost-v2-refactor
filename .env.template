# IPAT Data Watchdog Environment Configuration
# Copy this file to .env and modify as needed

PYTHONPATH=.

# PC Plugin Configuration
# PC_NAME determines which PC plugin to load for PC-specific settings
# Available options: default_pc_blb, lab_workstation_blb
PC_NAME=default_pc_blb

# Device Plugin Configuration  
# DEVICE_NAMES: Device plugins to load (can be multiple, comma-separated)
# Available options: sem_tischrem_blb, psa_horibalinks_blb
DEVICE_NAMES=sem_tischrem_blb

# Legacy single device name (kept for backward compatibility with build scripts)
DEVICE_NAME=sem_tischrem_blb
