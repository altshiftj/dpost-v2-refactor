    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug IPAT Watchdog",
            "type": "debugpy",
            "request": "launch",
            "module": "ipat_watchdog",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "CI_JOB_NAME": "tischrem_blb"
            }
        },
        {
            "name": "PowerShell: Launch Current File",
            "type": "PowerShell",
            "request": "launch",
            "script": "${file}",
            "args": []
        }
    ]
}