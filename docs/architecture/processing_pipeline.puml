@startuml ProcessingPipeline
title IPAT Data Watchdog – Processing Pipeline (Sequence)

actor FS as "Filesystem (watchdog)"
participant App as "DeviceWatchdogApp"
participant FPM as "FileProcessManager"
participant Resolver as "DeviceResolver"
participant Config as "ConfigService"
participant Factory as "FileProcessorFactory"
participant Proc as "FileProcessor (plugin)"
participant Stability as "FileStabilityTracker"
participant Routing as "routing.py"
participant Rename as "rename_flow.py"
participant RFlow as "record_flow.py"
participant RUtils as "record_utils.py"
participant Err as "error_handling.py"
participant FSUtil as "filesystem_utils.py"
participant UI as "UI (Tk/Adapter)"

== Event ingestion ==
FS -> App : created(file|folder)
App -> FPM : process_item(src_path)

== Early filters ==
alt internal staging path (.__staged__)
  FPM --> App : ProcessingResult(DEFERRED, "internal staging")
  return
end

== Device resolution ==
FPM -> Resolver : resolve(src_path)
Resolver -> Config : matching_devices(src_path)
alt no candidates
  FPM -> FSUtil : move_to_exception_folder(src_path)
  FPM --> App : ProcessingResult(REJECTED, reason)
else one candidate
  Resolver --> FPM : selected device (probe skipped)
else multiple candidates
  loop probe candidates
    Resolver -> Factory : get_for_device(device_id)
    Factory --> Resolver : Proc
    Resolver -> Proc : probe_file(src_path)
    Proc --> Resolver : FileProbeResult
  end
  Resolver --> FPM : selected device (best match or fallback)
end

== Stability guard ==
FPM -> Stability : wait()
alt rejected (timeout/disappeared)
  FPM -> Err : safe_move_to_exception(src_path)
  FPM --> App : ProcessingResult(REJECTED, reason)
  return
else stable
  Stability --> FPM : ok
end

== Device-scoped processing ==
FPM -> Config : activate_device(device)
activate Config
FPM -> Factory : get_for_device(device.identifier)
Factory --> FPM : Proc
FPM -> Proc : device_specific_preprocessing(src_path)
alt returns None
  FPM --> App : ProcessingResult(DEFERRED, "Awaiting paired artefact")
  deactivate Config
  return
else returns effective_path
  FPM -> FSUtil : parse_filename(strip_stage_suffix(effective_path))
  FSUtil --> FPM : (prefix, extension)
end

== Routing ==
FPM -> Routing : fetch_record_for_prefix(records, prefix, device)
Routing --> FPM : (sanitized_prefix, is_valid_format, record?)
FPM -> Routing : determine_routing_state(record, is_valid_format, prefix, extension, Proc)
Routing --> FPM : decision

alt UNAPPENDABLE
  FPM -> RFlow : handle_unappendable_record(UI, renameDelegate, context)
  RFlow -> Rename : obtain_valid_prefix(...)
  alt user cancels
    Rename -> FSUtil : move_to_rename_folder(...)
    UI <- Rename : info moved to rename
    FPM --> App : ProcessingResult(REJECTED)
    else user provides valid prefix
      FPM -> FPM : re-route with new prefix
  end
else APPEND_TO_SYNCED
  FPM -> RFlow : handle_append_to_synced_record(UI, add_item_to_record, renameDelegate, context)
else REQUIRE_RENAME
  FPM -> Rename : obtain_valid_prefix(current_prefix)
  alt user cancels
    Rename -> FSUtil : move_to_rename_folder(...)
    UI <- Rename : info moved to rename
    FPM --> App : ProcessingResult(REJECTED)
  else user provides valid prefix
    FPM -> FPM : re-route with new prefix
  end
else ACCEPT
  FPM -> RUtils : get_or_create_record / apply_device_defaults
  FPM -> Proc : device_specific_processing(effective, record_path, file_id, extension)
  Proc --> FPM : ProcessingOutput(final_path, datatype)
  FPM -> RUtils : update_record / manage_session
  FPM --> App : ProcessingResult(PROCESSED, final_path)
end

FPM -> Config : exit device context
deactivate Config

== Rejection surfacing (App) ==
App -> FPM : get_and_clear_rejected()
FPM --> App : [(path, reason), ...]
loop per rejected item
  App -> UI : show_error("Unsupported Input", reason)
end

note right of FPM
Metrics and side effects (from code):
 - FILES_FAILED increments on rejections/errors
 - FILE_PROCESS_TIME measures processing in App loop
 - Exceptions logged as JSON to C:/Watchdog/logs
 - Records synced on session end via RecordManager
end note

@enduml