# Environment defaults for local development
# Copy this file to .env for local overrides.

# Required startup selectors.
PC_NAME=your_pc_name
DEVICE_PLUGINS=your_device_plugin1,your_device_plugin2

# Optional HTTP ports for metrics and observability (dpost defaults are 8000/8001).
# PROMETHEUS_PORT=8000
# OBSERVABILITY_PORT=8001

# Optional log toggles.
# DPOST_LOG_FILE_ENABLED=true
# DPOST_LOG_FILE_PATH=C:/Watchdog/logs/watchdog.log
# LOG_FILE_PATH=C:/Watchdog/logs/watchdog.log